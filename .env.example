# Copy to .env and adjust. The server reads these.
PORT=8787
# Bind to loopback; expose privately with: tailscale serve 8787
BIND_ADDR=127.0.0.1
# Where channel directories are stamped. MUST be outside any git repo
# (Claude Code keys auto-memory off the git root, so siblings would share memory).
CHANNELS_ROOT=/home/venky/edupudi-channels
# Anthropic API key (supported path for an unattended backend).
ANTHROPIC_API_KEY=sk-ant-...
